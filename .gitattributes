# Default: text files normalized to LF in the repo, native EOL on checkout.
# This silences the "LF will be replaced by CRLF" warning on Windows.
* text=auto eol=lf

# Windows-only scripts must keep CRLF on disk to run reliably from Explorer.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Shell scripts always LF (they run on the Render/Linux build container).
*.sh    text eol=lf

# Source — explicit just to be safe.
*.py    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.toml  text eol=lf

# Binary files — never touch line endings.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.sqlite3 binary
*.db    binary
*.pyc   binary
*.so    binary
*.dll   binary
*.exe   binary
